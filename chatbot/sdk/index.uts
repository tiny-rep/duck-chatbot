import { reactive, watch, nextTick, computed } from 'vue';
import { currentUser, llmModelMap } from '../config';
import { Llm,ChatItem,Chat, MsgItem, RequestAiCoMessage, Userinfo, BaseMsgItem,
				Setting, MarkdownElItem, ImgItem, MultiModalContent, ImgParse
				, ThoughtItem } from '@/chatbot/types.uts';
export { MsgItem, ChatItem, BaseMsgItem, Userinfo, MarkdownElItem }
import {default as RequestAiWorker, RequestAiOptions, OnMessageOptions} from '@/chatbot/sdk/requestAiWorker.uts';
import proxyWeb from '@/chatbot/sdk/proxy-web.uts'
import { getConversationMessages, getAppConversations, deleteConversation, updateConversationName, stopChatWithExLinkToken } from '@/api/service.uts';
import testMarkdownText from './testMarkdownText.uts';
import { registerCustomProvider } from '@/chatbot/sdk/provider-registry.uts';
import { AiAgentOsAdapter } from './aiagent-os-adapter.uts';
import ParseMarkdown from '@/chatbot/sdk/parseMarkdown';
import treeToListSdk from '@/chatbot/sdk/treeToList';
import {MarkdownToken} from '@/uni_modules/uni-cmark'
import {Message, Step, Conversation} from '@/api/types.uts'
export {testMarkdownText}
export { isCustomProvider, providerSupportsTitleUpdate } from '@/chatbot/sdk/provider-registry.uts';


let requestAiWorker: RequestAiWorker | null = null
type BeforeRequestAiFn = () => void
type MessageHandlerMapFn = () => void
class UniAi {
	canRenderVue: boolean = true
	get canRender(): boolean {
		return this.canRenderVue
	}
	set canRender(value: boolean) {
		if (this.canRenderVue != value) {
			this.canRenderVue = value
			requestAiWorker?.postMessage({
				type: 'setCanRender',
				value: value
			} as UTSJSONObject)
		}
	}
	imgList: ImgItem[] = reactive<ImgItem[]>([]);
	// 当前用户
	currentUser: Userinfo = currentUser
	setting: Setting = reactive<Setting>({
		// UI 主题
		theme: 'light',
		// 语言
		language: 'zh-CN',
		// 大模型
		llm: {
			// 当前提供商
			provider: '',
			// 当前模型
			model: '',
			// 模型访问token
			ex_link_token: '',
			// agent的编号
			agentic_id: '',
			// 描述
			agentic_desc: '',
			// 是否开启联网搜索
			webSearch: false
		}
	})
	// 大模型
	get llm(): Llm {
		return this.setting.llm
	}
	set llm(value: Llm) {
		this.setting.llm = value
	}

	chat: Chat = reactive<Chat>({
		datas: reactive<ChatItem[]>([]) as ChatItem[],
		activeId: '',
		state: ''
	})
	/*
	chat太大，分为3个部分，方便与 storage 完美映射，实现数据同步
	1. uni-ai-chat 会话列表
	2. uni-ai-chat-msg-ids 会话对应的消息 id 列表，key 为：uni-ai-chat-msg-ids_chatId_${chatId}
	3. uni-ai-chat-msg-list 消息列表，key 为：消息 id，value 为：消息内容，key 为：uni-ai-chat-msg-list_msgId_${msgId}
	 */
	
	// 当前对话
	get currentChat(): ChatItem | null {
		return this.chat.datas.find((item) => item.id == this.chat.activeId) as ChatItem | null
	}
	
	getLocalMsgId(): string {
	  // 16 进制字符集
	  const hexChars = "0123456789abcdef"
	  // UUID 固定长度 36 位（包含 4 个横杠）
	  const uuidParts: string[] = []
	
	  // 逐段生成（标准 UUID v4 分段结构）
	  for (let i = 0; i < 36; i++) {
		if (i == 8 || i == 13 || i == 18 || i == 23) {
		  uuidParts.push("-")
		} 
		// 第 15 位固定为 4（UUID 版本标识）
		else if (i == 14) {
		  uuidParts.push("4")
		} 
		// 第 20 位只能是 8/9/a/b
		else if (i == 19) {
		  const randomValue = (Math.random() * 4 | 0) + 8
		  uuidParts.push(hexChars[randomValue].toString())
		} 
		// 其他位随机生成
		else {
		  const randomValue = Math.random() * 16 | 0
		  uuidParts.push(hexChars[randomValue].toString())
		}
	  }
	
	  // 拼接成最终字符串（UTS 支持数组 join）
	  return uuidParts.join("")
	}
	
	// 生成新会话的临时ID，用于标记未与后端同步的会话
	getNewChatTempId(): string {
		// 生成一个以 new_ 前缀开头的临时ID
		return 'new_' + this.getLocalMsgId();
	}
	
	addChat(checkEmpty: boolean = true) {
		// 检查是否已经存在空会话，如果存在则直接选中，否则创建新会话
		const lastItem = this.chat.datas.length == 0 ? null : this.chat.datas[0] as ChatItem | null;

		if (!checkEmpty || lastItem?.msgList.length != 0) {
			const newChat: ChatItem = {
				id: this.getNewChatTempId(), // 使用临时ID标记新会话
				title: "新对话",
				state: 'none',
				update_time: Date.now(),
				msgList: reactive<MsgItem[]>([]),
				inputContent: ''
			};
			this.chat.datas.push(newChat);
		}
		console.log(this.chat.datas)
		// 选中新创建的会话
		nextTick(() => {
			if(this.chat.datas != null) {
				this.chat.activeId = this.chat.datas[this.chat.datas.length - 1].id
			}
		})
	}
	
	async deleteChat(chatId: string): Promise<void> {
		try {
			// 调用接口删除会话
			const response = await deleteConversation(chatId, this.currentUser!._id!);
			if (response.code != 'success') {
				console.error('删除会话失败:', response.message);
			}
			
			// 如果只有一个，删之前需要先创建一个并设置为选中，否则会照成无选中会话导致崩溃
			if (uniAi.chat.datas.length == 1) {
				uniAi.addChat(false)
				this.chat.activeId = uniAi.chat.datas[0].id
			} else if (uniAi.chat.activeId == chatId) {
				// 如果删除的是当前激活的对话，则激活其他对话
				const otherChat = uniAi.chat.datas.find((item) => item.id != chatId)!
				uniAi.chat.activeId = otherChat.id
			}
			nextTick(() => {
				const index = uniAi.chat.datas.findIndex((item) => item.id == chatId)
				uniAi.chat.datas.splice(index, 1)
			})
		} catch (error) {
			console.error('删除会话失败:', error.message);
		}
	}
		
	get lastAiMsg(): MsgItem | null {
		// 获取Ai的最后一条消息(因为 msg 是倒叙的，所以取第一条)
		if (this.currentChat != null) {
			const length = this.currentChat!.msgList.length
			return length > 0 ? this.currentChat!.msgList[length - 1] : null;
		} else {
			return null;
		}
	}
	
	constructor() {

		// 注册 AI Agent OS 适配器
		this.registerAiAgentOsAdapter();
		
		// 监听会话切换，加载历史消息
		watch(():string => { return this.chat.activeId }, async (newChatId: string) => {
			if (newChatId != null && !newChatId.startsWith('new_') && this.currentUser != null && this.currentUser._id != null) {
				// 加载历史消息
				await this.loadHistoryMessages(newChatId, this.currentUser._id!);
			}
		}, { immediate: true });

		// 获取 setting
		uni.getStorage({
			key: 'uni-ai-setting',
			success: (res) => {
				if (res.data != null) {
					const setting = JSON.parse<Setting>(JSON.stringify(res.data)) as Setting
					// TODO: 如果直接对this.setting赋值会导致响应式丢失
					this.setting.theme = setting.theme
					this.setting.language = setting.language
					this.setting.llm = setting.llm
				}
			},
			fail: (err) => {
				// console.error('uni-ai-setting 获取失败', err)
			}
		})
		
		// 监听设置变化，自动保存设置
		watch((): Setting => this.setting, () => {
			// 通知代理web设置变化
			proxyWeb.callMethod({
				action: 'setSetting',
				data: this.setting
			}, (res) => {
				console.log('setSetting', res)
			})
			// 自动保存设置到本地
			uni.setStorage({
				key: 'uni-ai-setting',
				data: this.setting,
				success: () => {
					// console.log('uni-ai-setting 存储成功', this.setting)
				},
				fail: (err) => {
					console.error('uni-ai-setting 存储失败', err)
				}
			})
		}, { deep: true, immediate: true })
	}

	// 更新会话标题 和 会话更新时间
	updateChatUpdateTime(chatId: string) {
		const chat = this.chat.datas.find(chat => chat.id == chatId)
		if (chat != null) {
			chat.update_time = Date.now()
		} else {
			throw new Error('updateChatUpdateTime 对话不存在' + chatId)
		}
	}
	async updateChatTitle(chatId: string, title: string): Promise<void> {
		try {
			// 调用接口更新会话标题
			const response = await updateConversationName(chatId, this.currentUser._id ?? 'tmp_user_', title, null);
			if (response.code !== 'success') {
				console.error('更新会话标题失败:', response.message);
				throw new Error('更新会话标题失败');
			}
			
			const chat = this.chat.datas.find(chat => chat.id == chatId)
			if (chat != null) {
				chat.title = title
			} else {
				console.error('updateChatTitle 对话不存在', chatId)
				throw new Error('updateChatTitle 对话不存在')
			}
		} catch (error) {
			console.error('更新会话标题失败:', error);
			throw error;
		}
	}
	

	
	addMsg(msg: BaseMsgItem): MsgItem {
		// 添加一条消息
		const msgList = this.currentChat!.msgList
		const newMsg = {
			...msg,
			chat_id: this.currentChat!.id,
			_id: this.getLocalMsgId(),
			create_time: Date.now(),
			state: 0,
			markdownElList: [] as MarkdownElItem[],
			rendered: false,
			thoughts: [] as ThoughtItem[]
		} as MsgItem
		msgList.push(newMsg)
		if (msg.from_uid != 'uni-ai') {
			// 把用户提的问题 内容的前 20 个字符作为标题，去掉换行符
			const title = msg.body.substring(0, 20).replace(/\n/g, '')
			this.currentChat!.title = title
		}
		// 更新会话的更新时间
		this.updateChatUpdateTime(this.currentChat!.id)
		// 返回响应式的 msg
		return msgList[msgList.length - 1]
	}
	
	deleteMsg(msgId: string) {
		// 查出消息索引
		const msgList = this.currentChat!.msgList
		const index = msgList.findIndex((item) => item._id == msgId)
		if (index != -1) {
			msgList.splice(index, 1)
		} else {
			console.error('需要删除的消息未找到', msgId, this.currentChat!.msgList)
			throw new Error('需要删除的消息未找到')
		}
	}
	
	async abortRequest() {
		// 终止请求
		requestAiWorker?.postMessage({
			type: 'abortRequest'
		} as UTSJSONObject)

		// 停止特定的会话
		const targetChatId = this.currentChat?.id;
		if (targetChatId != null) {
			try {
				// 调用API停止会话
				const response = await stopChatWithExLinkToken(
					this.llm.ex_link_token??'',
					targetChatId
				);
				
				if (response.code == 'success') {
					console.log('会话停止成功', targetChatId);
				} else {
					console.error('会话停止失败', response.message);
				}
			} catch (error) {
				console.error('停止会话时发生错误', error);
			}
		}
	}
	
	async sendMsg(inputContent: string = ''): Promise<void> {
		// 发送消息
		if (inputContent == '') {
			inputContent = this.currentChat!.inputContent
		}
		// 去除前后空格
		inputContent = inputContent.trim()
		if (inputContent.length == 0) {
			throw new Error('发给 AI 的消息不能为空');
		}
		console.log('send inputContent', inputContent);
		// 生成用户提问的消息
		let baseUserMsg: BaseMsgItem = {
			body: inputContent,
			from_uid: this.currentUser._id ?? 'tmp_user_'
		}
		// 如果有图片
		if (this.imgList.length > 0) {
			baseUserMsg.img_url_list = this.imgList.map((item:ImgItem):string => item.path)
			this.imgList.length = 0
		}
		const userMsg: MsgItem = this.addMsg(baseUserMsg)

		// 生成一条空的 ai 回复的内容
		let baseAiMsgItem: BaseMsgItem = {
			body: '', // 初始是空的，后面慢慢追加
			from_uid: "uni-ai",
			about_msg_id: userMsg._id
		}
		const aiMsgItem: MsgItem = this.addMsg(baseAiMsgItem)
		return this.answerQuestion(aiMsgItem)
	}
	resetMsg(msg: MsgItem) {
		msg.body = ''
		msg.rendered = false
		msg.error_msg = null
		msg.thinkContent = null
		msg.markdownElList = []
	}
	
	// 回答问题
	answerQuestion(aiMsgItem: MsgItem) {
		// 重新回答问题了，之前的回调需要清除
		proxyWeb.callbackMap.clear()
		this.updateChatUpdateTime(this.currentChat!.id)
		this.currentChat!.state = 'processing';	
		const messages = this.getMsgToAi(this.currentChat!)
		const requestAiOptions: RequestAiOptions = {
			type: 'requestAi',
			messages,
			llm: this.llm as Llm,
			chat_id: this.currentChat!.id
		}
		requestAiWorker = new RequestAiWorker()
		requestAiWorker?.postMessage(requestAiOptions)
		requestAiWorker?.onMessage((message: any) => {
			if (!(message instanceof OnMessageOptions)){
				console.log('onMessage 类型错误', message)
				return
			}
			message = message as OnMessageOptions
			// console.log('answerQuestion message', message)
			const data = message.data
			const messageHandlerMap = new Map<string, MessageHandlerMapFn>([
				['setMarkdownElList', () => {
					if (this.currentChat == null) {
						return
					}
					if (this.currentChat.state == 'stop') {
						console.log('setMarkdownElList 当前对话已停止，忽略消息')
						return
					}
					const action = message.action
					const markdownElList = message.markdownElList
					if (action == 'set' && markdownElList != null) {
						aiMsgItem.markdownElList = markdownElList!
					} else if (action == 'update') {
						if (message.index! < aiMsgItem.markdownElList.length) {
							const markdownEl = message.markdownElList![0]
							// console.log('markdownEl', markdownEl)
							if (markdownEl.type == 'list'){
								const oldList = aiMsgItem.markdownElList[message.index!].datasList[0]
								const newList = markdownEl.datasList[0]
								const oldLen = oldList.length, newLen = newList.length
								// 如果新的还没旧的长，则直接删除丢失的项
								if (newLen < oldLen) {
									oldList.splice(newLen, oldLen - newLen)
									// console.warn('删除', newLen, oldLen)
								} else {
									// 先找到旧数据中，对于新的数据中第一个不相同的索引（倒序避免扫整个列表）
									let noDiffIndex = oldLen
									for (let i = oldLen - 1; i >= 0; i--) {
										// 如果新的和旧的第一个不相同的索引
										if (oldList[i].text == newList[i].text) {
											noDiffIndex = i
											break
										}
									}
									// 用新List将oldList原地更新为与newList一致（更高效且易于维护）
									oldList.splice(noDiffIndex, oldList.length - noDiffIndex, ...newList.slice(noDiffIndex))
								}
							} else {
								aiMsgItem.markdownElList[message.index!] = markdownEl
							}
						} else {
							console.error('setMarkdownElList 索引越界', message.index!, aiMsgItem.markdownElList.length)
						}
					} else if (action == 'remove') {
						aiMsgItem.markdownElList.splice(message.index!, message.size!)
					} else if (action == 'add') {
						aiMsgItem.markdownElList.push(...markdownElList!)
					}
					
					// console.warn("setMarkdownElList 耗时", Date.now() - start)
				}],
				['setThinkContent', () => {
					aiMsgItem.thinkContent = data as string
				}],
				['setMsgBody', () => {
					aiMsgItem.body = data as string
				}],
				['setMsgState', () => {
					this.currentChat!.state = data as string
				}],
				['setErrorMsg', () => {
					aiMsgItem.error_msg = data as string
				}],
				['setAiMsg', () => {
					// 更新aiMsgItem的thoughts数组，根据thought_id查找或添加thought项
					// #ifdef WEB
					const aiMsgData = data as OnMessageOptions
					// #endif
					// #ifdef APP
					const aiMsgData = JSON.parse<OnMessageOptions>(data as string);
					// #endif
					if (aiMsgData != null) {
						// 初始化thoughts数组（如果不存在）
						if (aiMsgItem.thoughts == null) {
							aiMsgItem.thoughts = [];
						}
						
						// 构建thought对象
						const thoughtObj: ThoughtItem = {
							id: aiMsgData.thought_id??'',
							position: aiMsgData.thought_position??0,
							event_type: aiMsgData.eventType??'',
							thought: aiMsgData.thought_body??'',
							observation: aiMsgData.thought_observation??'',
							tool: aiMsgData.thought_tool??'',
							tool_input: aiMsgData.thought_tool_input??'',
							latency: aiMsgData.thought_latency??0
						};
						
						const thoughtIdx = aiMsgItem.thoughts.findIndex((item) => item?.id == aiMsgData.thought_id);
						
						if (thoughtIdx == -1) {
							// 数据不存在则添加
							aiMsgItem.thoughts.push(thoughtObj);
						} else {
							// 数据存在则直接替换整个对象
							aiMsgItem.thoughts[thoughtIdx] = thoughtObj;
						}
					}
				}],
				['setCurrentChatState', () => {
					this.currentChat!.state = data as string
					if (data == 'stop') {
						aiMsgItem.rendered = true
					}
				}],
				['setRendered', () => {
					aiMsgItem.rendered = data as string == 'true'
				}],
				['setChatTitle', () => {
					const _data = data as string
					this.updateChatTitle(aiMsgItem.chat_id, _data)
				}],
				['updateConversationId', () => {
					// 更新会话ID，处理新会话的情况
					const newConversationId = data as string
					if (newConversationId != null && this.currentChat != null) {
						// 查找会话在列表中的索引
						const chatIndex = this.chat.datas.findIndex(chat => chat.id == this.currentChat!.id)
						if (chatIndex != -1) {
							// 更新会话ID
							this.chat.datas[chatIndex].id = newConversationId
							// 更新当前活跃会话ID
							this.chat.activeId = newConversationId
							// 更新消息列表中的chat_id
							this.currentChat.msgList.forEach(msg => {
								msg.chat_id = newConversationId
							})
							console.log('会话ID更新成功:', newConversationId)
						}
					}
				}]
			])
			const handler = messageHandlerMap.get(message.type)
			if (handler != null) {
				handler()
			} else {
				console.error('other answerQuestion message', message)
			}

		})
	}
	
	// 拿到消息列表，用于发给 AI 
	getMsgToAi(chatItem: ChatItem): RequestAiCoMessage[] {
		const messages: RequestAiCoMessage[] = [];
		chatItem.msgList.forEach((item) => {
			let content: string | MultiModalContent = item.body
			if (item.from_uid != 'uni-ai' && (item.img_url_list?.length ?? 0) > 0) {
				content = item.img_url_list!.map((url: string): ImgParse => {
					return {
						type: 'image_url',
						image_url: {
							url: url
						}
					}
				})
				content.push({
					type: 'text',
					text: item.body
				})
			}
			messages.push({
				role: item.from_uid == 'uni-ai' ? 'assistant' : 'user',
				content
			})
		})
		return messages
	}
	
	// 监听请求 AI 前的回调
	beforeRequestAiFns: BeforeRequestAiFn[] = []
	onBeforeRequestAi(fn: BeforeRequestAiFn) {
		this.beforeRequestAiFns.push(fn)
	}
	emitBeforeRequestAi() {
		this.beforeRequestAiFns.forEach((fn) => {
			fn()
		})
	}
	
	// 转换
	token2el(token : MarkdownToken) : MarkdownElItem {
		return {
			uniqueId: token.uniqueId!,
			type: token.type!,
			datasList: treeToListSdk.markTreeToList(token)
		}
	}

	// 加载历史消息
	async loadHistoryMessages(conversationId: string, endUserId: string) {
		try {
			// 获取当前会话
			const chatItem = this.chat.datas.find(item => item.id == conversationId);
			if (chatItem == null) {
				console.error('加载历史消息失败: 会话不存在', conversationId);
				return;
			}
			
			// 设置加载状态
			chatItem.state = 'loading';
			
			// 调用接口获取历史消息
			const response = await getConversationMessages(conversationId, endUserId);
			
			if (response.code == 'success' && response.data != null) {
				// 清空现有消息
				if (chatItem.msgList.length > 0) {
					chatItem.msgList.splice(0, chatItem.msgList.length);
				}
				
				// 添加历史消息
				[...response!.data.list].reverse().forEach((message: Message) => {
					// 用户消息
					const userMsg: MsgItem = {
						_id: message.id + '_user',
						body: message.query ?? '',
						from_uid: this.currentUser._id ?? '',
						chat_id: conversationId,
						create_time: message.created_at,
						state: 0,
						markdownElList: [],
						thoughts: [],
						rendered: true
					};
					chatItem.msgList.push(userMsg);
					
					// AI 消息
					const aiMsg: MsgItem = {
						_id: message.id + '_ai',
						body: message.answer ?? '',
						from_uid: 'uni-ai',
						chat_id: conversationId,
						create_time: message.created_at,
						state: 0,
						markdownElList: [],
						thoughts: [],
						rendered: true,
						about_msg_id: userMsg._id
					};
					// 实现对thoughts的解析
					aiMsg.thoughts = [];
					if (message.agent_thoughts != null && Array.isArray(message.agent_thoughts)) {
						message.agent_thoughts.forEach((thought: Step) => {
							let validEventType = thought.event
							aiMsg.thoughts.push({
									position: 0,
									id: thought.id,
									event_type: validEventType,
									thought: thought.thought ?? '',
									observation: thought.observation ?? '',
									tool: thought.tool ?? '',
									tool_input: '',
									latency: thought.latency
							});
						});
					}

					// 解析 Markdown 内容
        	if (message.answer != null) {
						chatItem.msgList.push(aiMsg);
						// 使用闭包捕获当前消息的引用
						(function(currentMsg: MsgItem, that: UniAi) {
							// 创建临时的 ParseMarkdown 实例
							const tempParser = new ParseMarkdown((markdownTokenList, isParseDone) => {
								if (isParseDone) {
									// 1. 生成最终的 markdownElList
									const finalElList: MarkdownElItem[] = [];
									markdownTokenList.forEach((token) => {
											finalElList.push(that.token2el(token));
									});

									// 2. 在 chatItem.msgList 中找到对应的消息对象
									const targetMsgIndex = chatItem.msgList.findIndex(m => m._id == currentMsg._id);
									
									if (targetMsgIndex != -1) {
											// 3. 直接修改找到的对象的属性
											chatItem.msgList[targetMsgIndex].markdownElList = finalElList;
											chatItem.msgList[targetMsgIndex].rendered = true;
											
											// 4. 【强制触发响应式更新】
											nextTick();
									}
								}
							});
							
							// 执行解析
							tempParser.runTask(message.answer);

							// 标记消息接收完成
							tempParser.msgReceiveDone = true;
							
						})(aiMsg, this);
        	} else {
        		chatItem.msgList.push(aiMsg);
        	}
				});
			} else {
				console.error('加载历史消息失败: 接口返回错误', response.message);
			}
		} catch (error) {
			console.error('加载历史消息失败:', error);
		} finally {
			// 重置会话状态
			const chatItem = this.chat.datas.find(item => item.id == conversationId);
			if (chatItem != null) {
				chatItem.state = 'none';
			}
		}
	}
	
	// 手动刷新历史消息
	async refreshHistoryMessages() {
		if (this.currentChat != null) {
			await this.loadHistoryMessages(this.currentChat.id, this.currentUser!._id!);
		}
	}
	
	// 加载历史会话列表
	async loadHistoryConversations() {
		try {
			// 设置加载状态
			this.chat.state = 'loading';
			
			const end_user_id = this.currentUser._id;

			// 调用接口获取历史会话列表
			const response = await getAppConversations(this.llm.ex_link_token ?? '', end_user_id ?? '');
			
			if (response.code == 'success' && response.data != null) {
				// 清空现有会话
				this.chat.datas = [];
				
				// 添加历史会话
				response.data!.forEach((conversation: Conversation) => {
					const chatItem: ChatItem = {
						id: conversation.id,
						title: conversation.name ?? '未命名对话',
						state: 'none',
						update_time: conversation.created_at,
						msgList: reactive<MsgItem[]>([]),
						inputContent: ''
					};
					this.chat.datas.push(chatItem);
				});
				
				// 如果没有会话，创建一个新会话
				if (this.chat.datas.length == 0) {
					this.addChat(false);
				} else {
					// 默认选中第一个会话
					this.chat.activeId = this.chat.datas[0].id;
				}
			} else {
				console.error('加载历史会话列表失败: 接口返回错误', response.message);
				// 如果接口调用失败，创建一个新会话
				this.addChat(false);
			}
		} catch (error) {
			console.error('加载历史会话列表失败:', error);
			// 如果发生错误，创建一个新会话
			this.addChat(false);
		} finally {
			// 重置加载状态
			this.chat.state = 'none';
		}
	}
	
	// 手动刷新历史会话列表
	async refreshHistoryConversations() {
		await this.loadHistoryConversations();
	}
	
	// 注册 AI Agent OS 适配器
	registerAiAgentOsAdapter() {
		// 从 llmModelMap 中获取 aiagent-os Provider
    const aiagentOsProvider = llmModelMap.get('aiagent-os');
    if (aiagentOsProvider != null) {
        registerCustomProvider('aiagent-os', new AiAgentOsAdapter(aiagentOsProvider));
    } else {
        console.error('aiagent-os provider not found in llmModelMap');
    }
	}
}

const uniAi = new UniAi()
export { uniAi }
export default uniAi

// 抛出主题
export const uiTheme = computed<string>(() => uniAi.setting.theme)

// #ifdef WEB
// 方便在控制台观察
window.uniAi = uniAi
// #endif