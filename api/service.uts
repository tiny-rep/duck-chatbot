/**
 * 获取指定应用的会话列表(终端用户)
 * @param exLinkToken 应用的ex_link_token
 * @param endUserId 终端用户ID
 * @param pinned 是否获取置顶的会话列表，默认为false
 * @param accessToken 访问令牌
 * @returns 会话列表
 */
export async function getAppConversations(
  exLinkToken: string,
  endUserId: string,
  pinned: boolean = false
): Promise<ApiResponse<Conversation[]>> {
  return get<Conversation[]>(
    `/web-apps/${exLinkToken}/conversations/${endUserId}/ex-link`,
    {
      params: {
        pinned
      }
    }
  );
}