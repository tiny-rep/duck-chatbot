 * @returns 响应数据
 */
export async function autoLogin(nickName: string, appId: string, unionId: string): Promise<ApiResponse<object>> {
    // 创建data对象
    const data = new UTSJSONObject();
    data.set('nick_name', nickName);
    data.set('app_id', appId);
    data.set('union_id', unionId);
    
    const config: RequestConfig = {
        data: data
    } as RequestConfig;
    
    const response: UTSJSONObject = await post('/openapi/auth/auto-login', config);
    
    // 使用parse方法转换类型
	// #ifdef WEB
	return response
	// #endif
	// #ifdef APP
    return response.parse<ApiResponse<object>>()!;
	// #endif
}

