/**
 * 获取应用分页列表(对外应用广场)
 * @param currentPage 当前页数，默认1
 * @param pageSize 每页条数，默认20
 * @param searchWord 搜索词
 * @param accessToken 访问令牌
 * @returns 应用列表
 */
export async function getAppsList(currentPage: number = 1, pageSize: number = 20, searchWord: string|null = null): Promise<ApiResponse<PaginationData<App>>> {
    // 创建params对象
    const params = new UTSJSONObject();
    params.set('current_page', currentPage);
    params.set('page_size', pageSize);
    if (searchWord != null) {
        params.set('search_word', searchWord);
    }
    
    const response: UTSJSONObject = await get('/openapi/apps/ex-link/list', {
        params: params
    } as RequestConfig);
    
    // 使用parse方法转换类型
	// #ifdef WEB
	return response
	// #endif
	// #ifdef APP
    return response.parse<ApiResponse<PaginationData<App>>>()!;
	// #endif
}

