 */
export async function deleteConversation(conversationId: string, endUserId: string): Promise<ApiResponse<object>> {
    const response: UTSJSONObject = await post(`/conversations/${conversationId}/delete/ex-link/${endUserId}`);
    
    // 使用parse方法转换类型
	// #ifdef WEB
	return response
	// #endif
	// #ifdef APP
    return response.parse<ApiResponse<object>>()!;
	// #endif
}

