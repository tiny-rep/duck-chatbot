        data: data,
        accessToken
    } as RequestConfig;
    
    const response: UTSJSONObject = await post(`/conversations/${conversationId}/name/ex-link/${endUserId}`, config);
    
    // 使用parse方法转换类型
	// #ifdef WEB
	return response
	// #endif
	// #ifdef APP
    return response.parse<ApiResponse<object>>()!;
	// #endif
}

